# Cantinarr server environment variables
# Copy to .env and fill in your values.

# TMDB (required for discover/search)
CANTINARR_TMDB_ACCESS_TOKEN=

# Anthropic (required for AI assistant)
CANTINARR_ANTHROPIC_KEY=

# Trakt (optional)
CANTINARR_TRAKT_CLIENT_ID=
CANTINARR_TRAKT_CLIENT_SECRET=

# Server
CANTINARR_DB_PATH=./dev.db
CANTINARR_PORT=8585
CANTINARR_SERVER_NAME=Cantinarr
CANTINARR_JWT_SECRET=
